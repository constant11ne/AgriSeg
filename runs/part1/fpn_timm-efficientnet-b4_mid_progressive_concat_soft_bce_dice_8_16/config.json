{
  "data_root": "../AgricultureVision",
  "model": "fpn",
  "encoder": "timm-efficientnet-b4",
  "encoder_weights": "imagenet",
  "use_nir": true,
  "oversample_rare": false,
  "freeze_encoder": false,
  "lora": false,
  "lora_rank": 4,
  "lora_alpha": 8,
  "bitfit": false,
  "loss": "soft_bce_dice",
  "class_weights": null,
  "tversky_alpha": 0.5,
  "tversky_beta": 0.5,
  "bce_weight": 0.12,
  "dice_weight": 0.88,
  "dice_smooth": 1e-05,
  "label_smoothing": 0.0,
  "batch_size": 16,
  "epochs": 12,
  "lr": 0.001,
  "max_grad_norm": 0.8,
  "weight_decay": 0.0001,
  "img_size": [
    256,
    256
  ],
  "num_workers": 8,
  "prefetch_factor": 4,
  "no_persistent_workers": false,
  "cache_root": "../AgricultureVision_cache_compact",
  "cache_mmap": true,
  "compile": false,
  "disable_amp": false,
  "device": "cuda",
  "seed": 42,
  "save_every": 1000,
  "save_last_every": 0,
  "log_every_n_steps": 50,
  "max_train_steps_per_epoch": 600,
  "max_val_steps_per_epoch": 200,
  "nir_fusion": "early",
  "nir_init_mode": "random",
  "norm": "bn",
  "logit_scales": null,
  "fusion_family": "mid",
  "fusion_method": "progressive_concat",
  "freeze_rgb_encoder": "none",
  "freeze_rgb_stages": 3,
  "partial_unfreeze_last_n": 2,
  "nir_branch_width": 0.5,
  "fusion_hidden_dim": 128,
  "nir_active_levels": 2,
  "align_norm_mode": "none",
  "late_fusion_checkpoint_rgb": null,
  "late_fusion_checkpoint_nir": null,
  "nir_pretrained_path": null,
  "phase1_freeze_epochs": 0,
  "runs_dir": "runs"
}